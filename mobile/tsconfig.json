{
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": true
  },
  "exclude": ["node_modules", "babel.config.js", "metro.config.js"]
}
